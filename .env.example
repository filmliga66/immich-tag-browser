# Copy to `.env` and fill in values. See IMPLEMENTATION_PLAN.md §8 for meanings.

# Base URL of the Immich instance the proxy talks to.
IMMICH_URL=https://immich.example.com

# HMAC key for signing the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-me-with-a-32-byte-hex-string

# Port the proxy listens on.
PORT=8080

# Set to `false` for plain http:// local dev.
COOKIE_SECURE=true

# Seconds to cache /api/tags in-memory.
TAGS_CACHE_TTL_SECONDS=60

# Fastify log level (trace|debug|info|warn|error|fatal).
LOG_LEVEL=info

# Allow IMMICH_URL to resolve to loopback / link-local / RFC1918 addresses.
# Keep `false` on public deployments; set `true` for LAN or docker-network Immich.
ALLOW_PRIVATE_IMMICH=false

# Extra origins allowed to make mutating requests (CSRF guard).
# Add the dev server origin here when running `pnpm dev` locally.
# Comma-separated. The server's own origin is always allowed automatically.
# Example: ALLOWED_ORIGINS=http://localhost:5173
ALLOWED_ORIGINS=
