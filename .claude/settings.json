{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install*)",
      "Bash(pnpm add*)",
      "Bash(pnpm remove*)",
      "Bash(pnpm run*)",
      "Bash(pnpm --filter *)",
      "Bash(pnpm exec*)",
      "Bash(pnpm dlx *)",
      "Bash(pnpm lint*)",
      "Bash(pnpm typecheck*)",
      "Bash(pnpm test*)",
      "Bash(pnpm build*)",
      "Bash(pnpm format*)",
      "Bash(pnpm dev*)",
      "Bash(node *)",
      "Bash(npx *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(git pull --ff-only*)",
      "Bash(git add *)",
      "Bash(git restore *)",
      "Bash(git push *)",
      "Bash(git stash*)",
      "Bash(git switch*)",
      "Bash(git checkout -b *)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr checks*)",
      "Bash(gh run view*)",
      "Bash(gh run list*)",
      "Bash(gh workflow view*)",
      "Bash(gh workflow list*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(docker build*)",
      "Bash(docker compose config*)",
      "Bash(docker compose ps*)",
      "Bash(docker image ls*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D *)",
      "Bash(rm -rf *)",
      "Bash(docker system prune*)",
      "Bash(docker volume rm*)"
    ]
  }
}
